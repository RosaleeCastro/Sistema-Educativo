Options -Indexes
RewriteEngine On

# Archivos PHP específicos que se sirven directamente
RewriteRule ^hash\.php$ - [L]
RewriteRule ^diagnostico\.php$ - [L]
RewriteRule ^instalar\.php$ - [L]

# Si el archivo existe físicamente lo sirve directo
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás va al enrutador
RewriteRule ^ index.php [QSA,L]

<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>