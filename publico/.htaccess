# ============================================================
# .htaccess — carpeta publico/
# Activa el módulo de reescritura de URLs de Apache y
# redirige todas las peticiones a index.php (el enrutador)
#
# Ejemplo:
#   /alumno/panel  →  index.php procesa la ruta /alumno/panel
#   /api/asistencia → index.php procesa la ruta /api/asistencia
#
# Las peticiones a archivos reales (CSS, JS, imágenes)
# se sirven directamente sin pasar por index.php
# ============================================================

Options -Indexes
RewriteEngine On

# Si el archivo solicitado existe físicamente (CSS, JS, imagen)
# lo sirve directamente — no pasa por el enrutador
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Todo lo demás va al enrutador
RewriteRule ^ index.php [QSA,L]

# Cabeceras de seguridad básicas
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>