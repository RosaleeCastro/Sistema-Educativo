# ============================================================
# PLANTILLA DE CONFIGURACIÓN — sistema-educativo
# Instrucciones: Copia este archivo como ".env" y completa
# los valores según tu entorno local.
# ============================================================

# Entorno actual: desarrollo | pruebas | produccion
ENTORNO=desarrollo

# Base de datos (Configuración local estándar)
DB_HOST=localhost
DB_PUERTO=3306
DB_NOMBRE=nombre_de_tu_bd
DB_USUARIO=usuario_bd
DB_CLAVE=tu_contraseña_segura

# URL base del proyecto (Importante para rutas y redirecciones)
# Ejemplo: http://localhost/sistema-educativo/publico
APP_URL=http://localhost/tu-carpeta/publico

# Seguridad — Cadena aleatoria de 32 caracteres
APP_CLAVE_SECRETA=genera_una_clave_de_32_caracteres_aqui

# IA local (Ollama - Configuración por defecto)
IA_URL=http://localhost:11434
IA_MODELO=llama3
IA_MAX_CONSULTAS_POR_SESION=10

# Subida de archivos
SUBIDAS_MAX_MB=10
SUBIDAS_TIPOS_PERMITIDOS=pdf,jpg,jpeg,png,mp4,zip