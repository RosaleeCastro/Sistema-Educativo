# ============================================================
# CONFIGURACIÓN DE ENTORNO — sistema-educativo
# ¡NUNCA subas este archivo a Git!
# Copia .env.ejemplo y rellena tus valores reales
# ============================================================

# Entorno actual: desarrollo | pruebas | produccion
ENTORNO=desarrollo

# Base de datos
DB_HOST=localhost
DB_PUERTO=3307
DB_NOMBRE=sistema_educativo
DB_USUARIO=root
DB_CLAVE=

# URL base del proyecto (sin barra final)
APP_URL=http://localhost/sistema-educativo/publico

# Seguridad — genera una cadena aleatoria larga y única
APP_CLAVE_SECRETA=cambia_esto_por_una_clave_aleatoria_larga_32chars

# IA local (Ollama)
IA_URL=http://localhost:11434
IA_MODELO=llama3
IA_MAX_CONSULTAS_POR_SESION=20

# Subida de archivos
SUBIDAS_MAX_MB=10
SUBIDAS_TIPOS_PERMITIDOS=pdf,jpg,jpeg,png,mp4,zip